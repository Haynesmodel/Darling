{
  "name": "darling-history",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "build:charts": "node scripts/build_chart_vendor.cjs",
    "build:hero": "node scripts/generate_hero_images.cjs",
    "generate:data-types": "node scripts/generate_asset_types.cjs",
    "generate:data-validators": "node scripts/generate_asset_validators.cjs",
    "generate:draft-spot": "python3 scripts/generate_draft_spot_asset.py",
    "generate:derived": "node scripts/generate_derived_stats.cjs",
    "generate:manifest": "node scripts/generate_asset_manifest.cjs",
    "generate:data": "npm run generate:draft-spot && npm run generate:data-types && npm run generate:data-validators && npm run generate:derived && npm run generate:manifest",
    "check:data-generated": "node scripts/check_generated_assets.cjs",
    "audit:dist": "node scripts/audit_built_assets.cjs dist",
    "check:bundle": "node scripts/check_bundle_size.cjs",
    "predev": "node scripts/sync_public_assets.cjs",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/sync_public_assets.cjs",
    "build": "npm run check:data-generated && npm run test:assets && npm run typecheck && vite build && npm run audit:dist && npm run check:bundle",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "npm run test:data && npm run test:scripts",
    "test:assets": "node scripts/validate_assets.cjs",
    "test:charts": "node --test test/charting-*.test.js",
    "test:search": "node --test test/state-helpers.test.js test/history-game-query.test.js test/history-renderers.test.js",
    "test:tables": "node --test test/table-system.test.cjs",
    "test:data": "npm run test:assets && node test/data.test.js",
    "test:scripts": "node --test test/scripts.test.cjs test/coverage-pipeline.test.cjs test/data-pipeline.test.cjs test/data-integrity.test.cjs test/data-freshness.test.cjs test/runtime-loader.test.cjs test/app-state-controller.test.js test/theme-system.test.cjs test/current-season-odds.test.js test/draft-spot-model.test.cjs test/league-pulse-model.test.cjs test/router.test.cjs test/feature-registry.test.cjs test/feature-boundaries.test.cjs && python3 -m unittest discover -s test -p 'test_*.py'",
    "test:hygiene": "node scripts/check_repo_hygiene.cjs && npm run check:feature-boundaries",
    "lint:css": "stylelint \"src/**/*.css\"",
    "check:css": "node scripts/check_css_hygiene.cjs",
    "check:feature-boundaries": "node scripts/check_feature_boundaries.cjs",
    "test:a11y": "playwright test test/ui/accessibility.spec.js",
    "test:keyboard": "playwright test test/ui/keyboard-navigation.spec.js",
    "test:unit:core": "npm run check:data-generated && npm run build:charts && npm run typecheck && npm run test:hygiene && npm run test:data && npm run test:charts && npm run test:search && npm run test:tables && npm run test:scripts",
    "test:unit": "npm run lint:css && npm run check:css && npm run test:unit:core",
    "test:coverage": "node scripts/run_coverage.cjs",
    "test:ui": "playwright test",
    "test:ui:chromium": "playwright test --project=chromium",
    "test:ui:webkit": "playwright test --project=webkit-smoke",
    "test:ui:preview": "node scripts/run_playwright_preview.cjs",
    "test:ui:preview:chromium": "node scripts/run_playwright_preview.cjs chromium",
    "test:ui:preview:webkit": "node scripts/run_playwright_preview.cjs webkit",
    "serve": "npm run dev -- --port 8000",
    "test:ci": "node scripts/run_ci.cjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.13.3",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "c8": "12.0.0",
    "esbuild": "^0.28.1",
    "istanbul-lib-coverage": "3.2.2",
    "istanbul-lib-instrument": "6.0.3",
    "istanbul-lib-report": "3.0.1",
    "istanbul-reports": "3.2.0",
    "json-schema-to-typescript": "15.0.4",
    "sharp": "^0.35.3",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@tanstack/preact-table": "9.0.0-beta.38",
    "preact": "^10.29.7"
  }
}
